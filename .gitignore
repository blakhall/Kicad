# KiCad Library specific ignores
# Backup files created by KiCad (e.g., .kicad_sym.bak, .kicad_mod.bak)
*.bak
# Editor backup files (often Vim or other editors)
*~
# Legacy KiCad 5 symbol cache (less common in KiCad 6+)
*-cache.lib
# Legacy symbol documentation file (less common in KiCad 6+)
*.dcm
# Component association file (legacy)
*.cmp
# Footprint info cache folder (KiCad 6+ generates this)
fp-info-cache/
# Symbol info cache folder (KiCad 7+ generates this)
sym-info-cache/
.history/
# Legacy footprint library index file
*.fplib
# Backup of legacy documentation files
*.dcm.bak
# Backup of legacy symbol library files
*.lib.bak

# Operating System specific files
# macOS specific file
.DS_Store
# Windows specific file
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary folder
temp/